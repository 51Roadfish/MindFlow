# =============================================================================
# MindFlow 开发环境配置模板
# 复制此文件为 .env 并填入实际值后启动: docker compose up -d
# =============================================================================

# ---- MySQL 8.0 ----
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=mindflow
MYSQL_USER=mindflow
MYSQL_PASSWORD=mindflow123

# ---- PostgreSQL 15 + pgvector ----
POSTGRES_DB=mindflow
POSTGRES_USER=mindflow
POSTGRES_PASSWORD=mindflow123

# ---- JWT ----
# 生产环境请使用 openssl rand -base64 64 生成
JWT_SECRET=c2VjcmV0LWtleS1taW5kZmxvdy1hcHBsaWNhdGlvbi0yMDIzLXN1cGVyLXNlY3VyZQ==
JWT_EXPIRATION=86400000

# ---- AI: 对话模型 — 智谱 GLM-4-Flash ----
# 申请地址: https://open.bigmodel.cn/
OPENAI_CHAT_API_KEY=your_zhipu_api_key_here

# ---- AI: 嵌入模型 — 硅基流动 BAAI/bge-large-zh-v1.5 ----
# 申请地址: https://cloud.siliconflow.cn/
OPENAI_EMBEDDING_API_KEY=your_siliconflow_api_key_here

#!/bin/bash
# .git/hooks/pre-commit — 知识库一致性检查
# 安装: 从项目根目录执行 cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 跳过: SKIP_KNOWLEDGE_CHECK=1 git commit ...

if [ "$SKIP_KNOWLEDGE_CHECK" = "1" ]; then
  exit 0
fi

SKILLS_DIR=".skills"
HAS_CHANGES=0
MODIFIED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$|\.tsx$|\.ts$|\.xml$|\.yml$')

if [ -z "$MODIFIED_FILES" ]; then
  exit 0
fi

echo ""
echo "=== 知识库一致性检查 ==="

for skill_file in "$SKILLS_DIR"/skill-*.md; do
  if [ ! -f "$skill_file" ]; then continue; fi
  skill_name=$(basename "$skill_file" .md | sed 's/skill-//')

  for modified_file in $MODIFIED_FILES; do
    # 提取纯文件名和相对路径
    base_name=$(basename "$modified_file")
    if grep -q "$base_name\|$modified_file" "$skill_file" 2>/dev/null; then
      echo "  ⚠️  你修改了 $modified_file"
      echo "     被 $skill_name 引用"
      echo "     检查是否需要更新: code .skills/skill-$skill_name.md"
      HAS_CHANGES=1
    fi
  done
done

if [ "$HAS_CHANGES" -ne 0 ]; then
  echo ""
  echo "  提示: 运行 scripts/knowledge-diff-check.sh 查看详细影响分析"
  echo "  跳过: SKIP_KNOWLEDGE_CHECK=1 git commit ..."
  echo ""
fi

exit 0
